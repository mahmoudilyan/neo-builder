{
  "name": "@neo-builder/editor-react",
  "version": "0.0.0",
  "description": "React view binding: a Notion-like drag-and-drop landing-page builder over @neo-builder/core.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/index.css"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@neo-builder/compiler-form": "workspace:*",
    "@neo-builder/compiler-html": "workspace:*",
    "@neo-builder/compiler-mjml": "workspace:*",
    "@neo-builder/core": "workspace:*",
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2"
  },
  "devDependencies": {
    "@neo-builder/theme": "workspace:*",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --external react --external react-dom",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  }
}
