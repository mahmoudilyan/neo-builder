{
  "name": "@neo-builder/mcp",
  "version": "0.0.0",
  "description": "MCP Server surface for external AI agents to operate AI Builder.",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "neo-builder-mcp": "./dist/server.js"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@neo-builder/core": "workspace:*",
    "ws": "^8.21.1"
  },
  "scripts": {
    "build": "tsup src/index.ts src/server.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1"
  }
}
